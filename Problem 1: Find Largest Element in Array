#include <iostream>
using namespace std;

int main() {
    int arr[] = {4, 7, 1, 9, 2};

    int n = sizeof(arr) / sizeof(arr[0]);

    int maxVal = arr[0];

    for (int i = 1; i < n; i++) {
        if (arr[i] > maxVal) {
            maxVal = arr[i];
        }
    }

    cout << "Largest element = " << maxVal << endl;

    return 0;
}
